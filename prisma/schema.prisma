generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ORGANIZER
  ATTENDEE
  SCANNER
}

enum OrganizerApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum VenueStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PayoutMode {
  STRIPE_CONNECT
  AUTO
  MANUAL
}

enum StripeOnboardingStatus {
  NOT_STARTED
  PENDING
  COMPLETED
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
  CANCELLED
}

enum EventType {
  PHYSICAL
  ONLINE
}

enum EventVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum EventMode {
  SIMPLE
  RESERVED_SEATING
}

enum TicketTypeKind {
  DIRECT
  COMBO
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SeatBookingStatus {
  RESERVED
  BOOKED
}

enum SeatInventoryStatus {
  AVAILABLE
  RESERVED
  SOLD
  BLOCKED
}

enum TicketTransferStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  passwordHash     String
  role             Role
  emailVerified    Boolean                  @default(false)
  isActive         Boolean                  @default(true)
  marketingOptOut  Boolean                  @default(false)
  unsubscribeToken String                   @unique @default(cuid())
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organizerProfile OrganizerProfile?
  attendeeProfile  AttendeeProfile?
  refreshTokens    RefreshToken[]
  resetTokens      PasswordResetToken[]
  verifyTokens     EmailVerificationToken[]
  auditLogs        AuditLog[]
  compIssuances    CompTicketIssuance[]
  scannerProfile   ScannerProfile?
  scannerDevices   ScannerDevice[]
  notifications    Notification[]
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OrganizerProfile {
  id               String                   @id @default(cuid())
  userId           String                   @unique
  logoUrl          String?
  companyName      String?
  brandName        String?
  website          String?
  phone            String?
  alternatePhone   String?
  supportEmail     String?
  facebookPage     String?
  twitterUrl       String?
  instagramUrl     String?
  socialMediaLink  String?
  contactName      String?
  taxId            String?
  addressLine1     String?
  addressLine2     String?
  stateId          String?
  cityId           String?
  approvalStatus   OrganizerApprovalStatus  @default(DRAFT)
  rejectionReason  String?
  onboardingDoneAt DateTime?
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutSettings   OrganizerPayoutSettings?
  payoutRequests   PayoutRequest[]
  venues           Venue[]
  events           Event[]
  promoCodes       PromoCode[]
  eventSeries      EventSeries[]
  affiliateLinks   AffiliateLink[]
  scannerProfiles  ScannerProfile[]
}

model AttendeeProfile {
  id                   String                @id @default(cuid())
  userId               String                @unique
  displayName          String?
  phone                String?
  stripeCustomerId     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders               Order[]
  cancellationRequests CancellationRequest[]
  reviews              EventReview[]
  waitlists            Waitlist[]
}

model OrganizerPayoutSettings {
  id                     String                 @id @default(cuid())
  organizerProfileId     String                 @unique
  payoutMode             PayoutMode             @default(MANUAL)
  manualPayoutNote       String?
  stripeAccountId        String?
  stripeOnboardingStatus StripeOnboardingStatus @default(NOT_STARTED)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  organizerProfile       OrganizerProfile       @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id                 String              @id @default(cuid())
  organizerProfileId String
  amount             Decimal?
  note               String?
  status             PayoutRequestStatus @default(PENDING)
  adminNote          String?
  stripeTransferId   String?
  failureReason      String?
  requestedAt        DateTime            @default(now())
  resolvedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organizerProfile   OrganizerProfile    @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)

  @@index([organizerProfileId, status])
  @@index([requestedAt])
}

model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  livemode      Boolean
  payload       Json?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type])
  @@index([processedAt])
}

model PlatformConfig {
  id                   String     @id @default("singleton")
  platformName         String     @default("EventsBox")
  brandColor           String     @default("#000000")
  smtpFromName         String     @default("EventsBox")
  smtpFromEmail        String     @default("noreply@eventsbox.com")
  defaultCommissionPct Decimal    @db.Decimal(5, 2)
  defaultGstPct        Decimal    @db.Decimal(5, 2)
  payoutModeDefault    PayoutMode
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  venues    Venue[]
  events    Event[]
}

model Country {
  id        String   @id @default(cuid())
  code      String   @unique  // ISO 3166-1 alpha-2: "US", "BD", "AU", "GB"
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  states    State[]
  venues    Venue[]
  events    Event[]
}

model State {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String   @unique
  countryId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  country   Country? @relation(fields: [countryId], references: [id])
  cities    City[]
  venues    Venue[]
  events    Event[]
}

model City {
  id        String   @id @default(cuid())
  stateId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  venues    Venue[]
  events    Event[]

  @@unique([stateId, name])
  @@index([stateId])
}

model Venue {
  id                   String           @id @default(cuid())
  organizerProfileId   String
  name                 String
  addressLine1         String
  addressLine2         String?
  countryId            String?
  stateId              String
  cityId               String
  categoryId           String?
  lat                  Float?
  lng                  Float?
  seatingConfig        Json?
  seatState            Json?
  seatingSchemaVersion Int              @default(1)
  seatingUpdatedAt     DateTime?
  totalSeats           Int?
  totalTables          Int?
  status               VenueStatus      @default(PENDING_APPROVAL)
  rejectionReason      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  organizerProfile     OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  country              Country?         @relation(fields: [countryId], references: [id])
  state                State            @relation(fields: [stateId], references: [id])
  city                 City             @relation(fields: [cityId], references: [id])
  category             Category?        @relation(fields: [categoryId], references: [id])
  events               Event[]

  @@index([organizerProfileId])
  @@index([status])
}

model Event {
  id                 String           @id @default(cuid())
  organizerProfileId String
  seriesId           String?
  categoryId         String?
  venueId            String?
  countryId          String?
  stateId            String?
  cityId             String?
  title              String
  tagline            String?
  slug               String           @unique
  description        String?
  heroImage          String?
  images             String[]         @default([])
  eventType          EventType        @default(PHYSICAL)
  onlineAccessLink   String?
  visibility         EventVisibility  @default(PUBLIC)
  mode               EventMode        @default(SIMPLE)
  adminNote          String?
  contactEmail       String?
  contactPhone       String?
  lat                         Float?
  lng                         Float?
  cancelPolicy                String?
  refundPolicy                String?
  cancellationDeadlineHours   Int?
  refundPercent               Int      @default(100)
  customConfirmationMessage   String?
  startAt            DateTime
  endAt              DateTime
  timezone           String           @default("UTC")
  status             EventStatus      @default(DRAFT)
  rejectionReason    String?
  submittedAt        DateTime?
  publishedAt        DateTime?
  currency           String           @default("USD")
  commissionPct      Decimal          @default(10) @db.Decimal(5, 2)
  gstPct             Decimal          @default(15) @db.Decimal(5, 2)
  platformFeeFixed   Decimal          @default(0) @db.Decimal(10, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  series             EventSeries?     @relation(fields: [seriesId], references: [id])
  category           Category?        @relation(fields: [categoryId], references: [id])
  venue              Venue?           @relation(fields: [venueId], references: [id])
  country            Country?         @relation(fields: [countryId], references: [id])
  state              State?           @relation(fields: [stateId], references: [id])
  city               City?            @relation(fields: [cityId], references: [id])
  ticketTypes        TicketType[]
  orders             Order[]
  promoCodes         PromoCode[]
  tags               String[]         @default([])
  audience           String?
  isFeatured         Boolean          @default(false)
  videoUrl           String?
  reviewCount        Int              @default(0)
  avgRating          Float            @default(0)
  seatBookings       EventSeatBooking[]
  seatingSections    SeatingSection[]
  seatInventory      SeatInventory[]
  tableZones         TableZone[]
  waitlist           Waitlist[]
  affiliateLinks     AffiliateLink[]
  addOns             EventAddOn[]
  reviews            EventReview[]

  @@index([organizerProfileId])
  @@index([seriesId])
  @@index([status])
  @@index([startAt])
}

model EventSeries {
  id                   String           @id @default(cuid())
  organizerProfileId   String
  title                String
  description          String?
  recurrenceType       RecurrenceType?
  recurrenceDaysOfWeek Int[]            @default([])
  recurrenceEndDate    DateTime?
  createdAt            DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  events             Event[]

  @@index([organizerProfileId])
}

model TicketType {
  id          String         @id @default(cuid())
  eventId     String
  sectionId   String?
  name        String
  description String?
  kind        TicketTypeKind @default(DIRECT)
  price       Decimal        @db.Decimal(10, 2)
  quantity    Int
  sold        Int            @default(0)
  reservedQty Int            @default(0)
  compIssued  Int            @default(0)
  saleStartAt DateTime?
  saleEndAt   DateTime?
  maxPerOrder Int            @default(10)
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  waitlist    Waitlist[]
  compIssuances CompTicketIssuance[]

  @@index([eventId])
}

model PromoCode {
  id                 String           @id @default(cuid())
  organizerProfileId String
  eventId            String?
  code               String           @unique
  discountType       DiscountType
  discountValue      Decimal          @db.Decimal(10, 2)
  maxUses            Int?
  usedCount          Int              @default(0)
  expiresAt          DateTime?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  event              Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  orders             Order[]

  @@index([organizerProfileId])
  @@index([code])
}

model Order {
  id                    String               @id @default(cuid())
  eventId               String
  attendeeUserId        String?
  buyerEmail            String
  buyerName             String
  stripePaymentIntentId String?              @unique
  subtotal              Decimal              @db.Decimal(10, 2)
  platformFee           Decimal              @db.Decimal(10, 2)
  gst                   Decimal              @db.Decimal(10, 2)
  total                 Decimal              @db.Decimal(10, 2)
  promoCodeId           String?
  discountAmount        Decimal              @default(0) @db.Decimal(10, 2)
  status                OrderStatus          @default(PENDING)
  paidAt                DateTime?
  reminderSentAt        DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  event                 Event                @relation(fields: [eventId], references: [id])
  attendeeProfile       AttendeeProfile?     @relation(fields: [attendeeUserId], references: [id])
  promoCode             PromoCode?           @relation(fields: [promoCodeId], references: [id])
  items                 OrderItem[]
  seatBookings          EventSeatBooking[]
  tickets               QRTicket[]
  cancellationRequest   CancellationRequest?
  affiliateLinkId       String?
  affiliateLink         AffiliateLink? @relation(fields: [affiliateLinkId], references: [id])
  orderAddOns           OrderAddOn[]
  review                EventReview?
  seatInventory         SeatInventory[]

  @@index([eventId])
  @@index([attendeeUserId])
  @@index([buyerEmail])
  @@index([stripePaymentIntentId])
  @@index([promoCodeId])
  @@index([affiliateLinkId])
}

model CancellationRequest {
  id              String                    @id @default(cuid())
  orderId         String                    @unique
  attendeeUserId  String
  reason          String?
  status          CancellationRequestStatus @default(PENDING)
  adminNote       String?
  resolvedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attendeeProfile AttendeeProfile           @relation(fields: [attendeeUserId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id           String     @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(10, 2)
  subtotal     Decimal    @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
  tickets      QRTicket[]

  @@index([orderId])
  @@index([ticketTypeId])
}

model QRTicket {
  id           String    @id @default(cuid())
  orderId      String
  orderItemId  String
  token        String    @unique @default(cuid())
  ticketNumber String
  seatId       String?
  seatLabel    String?
  isComplimentary Boolean @default(false)
  isCheckedIn  Boolean   @default(false)
  checkedInAt  DateTime?
  checkedInDevice String?
  createdAt    DateTime  @default(now())
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  compIssuance CompTicketIssuance?
  transfers    TicketTransfer[]

  @@index([orderId])
  @@index([token])
}

model CompTicketIssuance {
  id              String     @id @default(cuid())
  ticketTypeId    String
  issuedByUserId  String
  recipientName   String
  recipientEmail  String
  note            String?
  qrTicketId      String     @unique
  createdAt       DateTime   @default(now())
  ticketType      TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  issuedBy        User       @relation(fields: [issuedByUserId], references: [id])
  qrTicket        QRTicket   @relation(fields: [qrTicketId], references: [id])

  @@index([ticketTypeId])
  @@index([issuedByUserId])
}

model TicketTransfer {
  id         String               @id @default(cuid())
  qrTicketId String
  fromEmail  String
  toEmail    String
  toName     String
  token      String               @unique @default(cuid())
  status     TicketTransferStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime             @default(now())
  qrTicket   QRTicket             @relation(fields: [qrTicketId], references: [id], onDelete: Cascade)

  @@index([qrTicketId])
  @@index([token])
}

model EventSeatBooking {
  id        String            @id @default(cuid())
  eventId   String
  orderId   String
  seatId    String
  seatLabel String
  status    SeatBookingStatus @default(RESERVED)
  expiresAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([eventId, seatId])
  @@index([orderId])
  @@index([eventId, status, expiresAt])
}

model SeatingSection {
  id        String          @id @default(cuid())
  eventId   String
  name      String
  color     String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rows      SeatingRow[]
  seats     SeatInventory[]

  @@index([eventId])
  @@index([eventId, sortOrder])
}

model SeatingRow {
  id        String          @id @default(cuid())
  sectionId String
  label     String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  section   SeatingSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  seats     SeatInventory[]

  @@index([sectionId])
  @@index([sectionId, sortOrder])
}

model SeatInventory {
  id        String              @id @default(cuid())
  eventId   String
  sectionId String
  rowId     String
  seatLabel String
  status    SeatInventoryStatus @default(AVAILABLE)
  orderId   String?
  expiresAt DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  event     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  section   SeatingSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  row       SeatingRow          @relation(fields: [rowId], references: [id], onDelete: Cascade)
  order     Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([eventId, seatLabel])
  @@index([eventId, status, expiresAt])
  @@index([sectionId])
  @@index([rowId])
  @@index([orderId])
}

model TableZone {
  id            String   @id @default(cuid())
  eventId       String
  name          String
  seatsPerTable Int
  totalTables   Int
  price         Decimal  @db.Decimal(10, 2)
  color         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Waitlist {
  id                String           @id @default(cuid())
  eventId           String
  ticketTypeId      String
  attendeeProfileId String?
  email             String
  name              String?
  notifiedAt        DateTime?
  createdAt         DateTime         @default(now())
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType        TicketType       @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  attendeeProfile   AttendeeProfile? @relation(fields: [attendeeProfileId], references: [id], onDelete: SetNull)

  @@unique([ticketTypeId, email])
  @@index([eventId])
  @@index([ticketTypeId])
  @@index([attendeeProfileId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  actionUrl String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([entityType, entityId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AffiliateLink {
  id                 String           @id @default(cuid())
  organizerProfileId String
  eventId            String?
  code               String           @unique
  label              String?
  commissionPct      Decimal          @default(10) @db.Decimal(5, 2)
  isActive           Boolean          @default(true)
  clickCount         Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  event              Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  orders             Order[]

  @@index([organizerProfileId])
  @@index([eventId])
}

model EventAddOn {
  id          String       @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Decimal      @db.Decimal(10, 2)
  maxPerOrder Int          @default(10)
  totalStock  Int?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderAddOns OrderAddOn[]

  @@index([eventId])
}

model OrderAddOn {
  id         String     @id @default(cuid())
  orderId    String
  addOnId    String
  name       String
  quantity   Int
  unitPrice  Decimal    @db.Decimal(10, 2)
  subtotal   Decimal    @db.Decimal(10, 2)
  createdAt  DateTime   @default(now())
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addOn      EventAddOn @relation(fields: [addOnId], references: [id])

  @@index([orderId])
  @@index([addOnId])
}

model ScannerProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  organizerProfileId String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizerProfileId])
}

model ScannerDevice {
  deviceId   String   @id
  name       String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EventReview {
  id             String          @id @default(cuid())
  eventId        String
  attendeeUserId String
  orderId        String          @unique
  rating         Int
  comment        String?         @db.Text
  isVisible      Boolean         @default(true)
  isFeatured     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee       AttendeeProfile @relation(fields: [attendeeUserId], references: [id], onDelete: Cascade)
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([eventId, attendeeUserId])
  @@index([eventId])
  @@index([eventId, isVisible])
  @@index([attendeeUserId])
  }
