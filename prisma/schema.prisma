generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ORGANIZER
  ATTENDEE
}

enum OrganizerApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum VenueStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PayoutMode {
  STRIPE_CONNECT
  MANUAL
}

enum StripeOnboardingStatus {
  NOT_STARTED
  PENDING
  COMPLETED
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
  CANCELLED
}

enum TicketTypeKind {
  DIRECT
  COMBO
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  passwordHash     String
  role             Role
  emailVerified    Boolean                  @default(false)
  isActive         Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organizerProfile OrganizerProfile?
  attendeeProfile  AttendeeProfile?
  refreshTokens    RefreshToken[]
  resetTokens      PasswordResetToken[]
  verifyTokens     EmailVerificationToken[]
  auditLogs        AuditLog[]
}

model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OrganizerProfile {
  id               String                   @id @default(cuid())
  userId           String                   @unique
  companyName      String?
  brandName        String?
  website          String?
  phone            String?
  alternatePhone   String?
  supportEmail     String?
  facebookPage     String?
  socialMediaLink  String?
  contactName      String?
  taxId            String?
  addressLine1     String?
  addressLine2     String?
  stateId          String?
  cityId           String?
  approvalStatus   OrganizerApprovalStatus  @default(DRAFT)
  rejectionReason  String?
  onboardingDoneAt DateTime?
  submittedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutSettings   OrganizerPayoutSettings?
  payoutRequests   PayoutRequest[]
  venues           Venue[]
  events           Event[]
  promoCodes       PromoCode[]
}

model AttendeeProfile {
  id                   String                @id @default(cuid())
  userId               String                @unique
  displayName          String?
  phone                String?
  stripeCustomerId     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders               Order[]
  cancellationRequests CancellationRequest[]
}

model OrganizerPayoutSettings {
  id                     String                 @id @default(cuid())
  organizerProfileId     String                 @unique
  payoutMode             PayoutMode             @default(MANUAL)
  manualPayoutNote       String?
  stripeAccountId        String?
  stripeOnboardingStatus StripeOnboardingStatus @default(NOT_STARTED)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  organizerProfile       OrganizerProfile       @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id                 String              @id @default(cuid())
  organizerProfileId String
  amount             Decimal?
  note               String?
  status             PayoutRequestStatus @default(PENDING)
  adminNote          String?
  requestedAt        DateTime            @default(now())
  resolvedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organizerProfile   OrganizerProfile    @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)

  @@index([organizerProfileId, status])
  @@index([requestedAt])
}

model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  type          String
  livemode      Boolean
  payload       Json?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type])
  @@index([processedAt])
}

model PlatformConfig {
  id                   String     @id @default("singleton")
  defaultCommissionPct Decimal    @db.Decimal(5, 2)
  defaultGstPct        Decimal    @db.Decimal(5, 2)
  payoutModeDefault    PayoutMode
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  venues    Venue[]
  events    Event[]
}

model State {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]
  venues    Venue[]
  events    Event[]
}

model City {
  id        String   @id @default(cuid())
  stateId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  venues    Venue[]
  events    Event[]

  @@unique([stateId, name])
  @@index([stateId])
}

model Venue {
  id                   String           @id @default(cuid())
  organizerProfileId   String
  name                 String
  addressLine1         String
  addressLine2         String?
  stateId              String
  cityId               String
  categoryId           String?
  seatingConfig        Json?
  seatState            Json?
  seatingSchemaVersion Int              @default(1)
  seatingUpdatedAt     DateTime?
  totalSeats           Int?
  totalTables          Int?
  status               VenueStatus      @default(PENDING_APPROVAL)
  rejectionReason      String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  organizerProfile     OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  state                State            @relation(fields: [stateId], references: [id])
  city                 City             @relation(fields: [cityId], references: [id])
  category             Category?        @relation(fields: [categoryId], references: [id])
  events               Event[]

  @@index([organizerProfileId])
  @@index([status])
}

model Event {
  id                 String           @id @default(cuid())
  organizerProfileId String
  categoryId         String?
  venueId            String?
  stateId            String?
  cityId             String?
  title              String
  slug               String           @unique
  description        String?
  heroImage          String?
  contactEmail       String?
  contactPhone       String?
  cancelPolicy       String?
  refundPolicy       String?
  startAt            DateTime
  endAt              DateTime
  timezone           String           @default("Pacific/Auckland")
  status             EventStatus      @default(DRAFT)
  rejectionReason    String?
  submittedAt        DateTime?
  publishedAt        DateTime?
  commissionPct      Decimal          @default(10) @db.Decimal(5, 2)
  gstPct             Decimal          @default(15) @db.Decimal(5, 2)
  platformFeeFixed   Decimal          @default(0) @db.Decimal(10, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  category           Category?        @relation(fields: [categoryId], references: [id])
  venue              Venue?           @relation(fields: [venueId], references: [id])
  state              State?           @relation(fields: [stateId], references: [id])
  city               City?            @relation(fields: [cityId], references: [id])
  ticketTypes        TicketType[]
  orders             Order[]
  promoCodes         PromoCode[]

  @@index([organizerProfileId])
  @@index([status])
  @@index([startAt])
}

model TicketType {
  id          String         @id @default(cuid())
  eventId     String
  name        String
  description String?
  kind        TicketTypeKind @default(DIRECT)
  price       Decimal        @db.Decimal(10, 2)
  quantity    Int
  sold        Int            @default(0)
  saleStartAt DateTime?
  saleEndAt   DateTime?
  maxPerOrder Int            @default(10)
  isActive    Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([eventId])
}

model PromoCode {
  id                 String           @id @default(cuid())
  organizerProfileId String
  eventId            String?
  code               String           @unique
  discountType       DiscountType
  discountValue      Decimal          @db.Decimal(10, 2)
  maxUses            Int?
  usedCount          Int              @default(0)
  expiresAt          DateTime?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  event              Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  orders             Order[]

  @@index([organizerProfileId])
  @@index([code])
}

model Order {
  id                    String               @id @default(cuid())
  eventId               String
  attendeeUserId        String?
  buyerEmail            String
  buyerName             String
  stripePaymentIntentId String?              @unique
  subtotal              Decimal              @db.Decimal(10, 2)
  platformFee           Decimal              @db.Decimal(10, 2)
  gst                   Decimal              @db.Decimal(10, 2)
  total                 Decimal              @db.Decimal(10, 2)
  promoCodeId           String?
  discountAmount        Decimal              @default(0) @db.Decimal(10, 2)
  status                OrderStatus          @default(PENDING)
  paidAt                DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  event                 Event                @relation(fields: [eventId], references: [id])
  attendeeProfile       AttendeeProfile?     @relation(fields: [attendeeUserId], references: [id])
  promoCode             PromoCode?           @relation(fields: [promoCodeId], references: [id])
  items                 OrderItem[]
  tickets               QRTicket[]
  cancellationRequest   CancellationRequest?

  @@index([eventId])
  @@index([attendeeUserId])
  @@index([buyerEmail])
  @@index([stripePaymentIntentId])
  @@index([promoCodeId])
}

model CancellationRequest {
  id              String                    @id @default(cuid())
  orderId         String                    @unique
  attendeeUserId  String
  reason          String?
  status          CancellationRequestStatus @default(PENDING)
  adminNote       String?
  resolvedAt      DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  order           Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attendeeProfile AttendeeProfile           @relation(fields: [attendeeUserId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id           String     @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(10, 2)
  subtotal     Decimal    @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
  tickets      QRTicket[]

  @@index([orderId])
  @@index([ticketTypeId])
}

model QRTicket {
  id           String    @id @default(cuid())
  orderId      String
  orderItemId  String
  token        String    @unique @default(cuid())
  ticketNumber String
  checkedInAt  DateTime?
  createdAt    DateTime  @default(now())
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([token])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([entityType, entityId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
