{
  "framework": "nextjs",
  "regions": ["syd1"],
  "buildCommand": "npm run build",
  "installCommand": "corepack enable && corepack prepare npm@10.8.2 --activate && npm ci --include=dev",
  "crons": [
    {
      "path": "/api/cron/cleanup-tokens",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/event-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/auto-payouts",
      "schedule": "0 10 * * 1"
    }
  ]
}
